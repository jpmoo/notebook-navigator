{
  "name": "notebook-navigator",
  "version": "3.0.0",
  "description": "Replace the default file explorer with a clean two-pane interface featuring folder tree, tag browsing, file previews, keyboard navigation, drag-and-drop, pinned notes, and customizable display options.",
  "main": "main.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "node scripts/build-icons.mjs && node scripts/build-styles.mjs && node esbuild.config.mjs",
    "build:icons": "node scripts/build-icons.mjs",
    "build:styles": "node scripts/build-styles.mjs",
    "build": "node scripts/build-styles.mjs && tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\"",
    "lint:styles": "npm run build:styles && stylelint \"src/styles/**/*.css\" \"styles.css\" --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "transform": "tsx codemods/run-transforms.ts",
    "transform:dry": "tsx codemods/run-transforms.ts --dry-run",
    "transform:imports": "tsx codemods/run-transforms.ts organize-imports",
    "transform:classes": "tsx codemods/run-transforms.ts sort-class-members",
    "transform:react": "tsx codemods/run-transforms.ts organize-react-components",
    "transform:react-internals": "tsx codemods/run-transforms.ts organize-react-internals"
  },
  "keywords": [],
  "author": "Johan Sanneblad",
  "license": "LicenseRef-NotebookNavigator",
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^9.39.4",
    "@types/jscodeshift": "^17.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitest/coverage-v8": "^4.1.7",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jscodeshift": "^17.3.0",
    "knip": "^6.14.2",
    "obsidian": "github:obsidianmd/obsidian-api#cf9ef454f6e0fa0f1f275b3e51991dfc557cc7be",
    "prettier": "^3.8.3",
    "recast": "^0.23.11",
    "stylelint": "^17.12.0",
    "stylelint-no-unsupported-browser-features": "^8.1.1",
    "tslib": "^2.8.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-virtual": "^3.13.24",
    "emoji-regex-xs": "^2.0.1",
    "emojilib": "^4.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
